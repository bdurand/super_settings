<!DOCTYPE html>
<html lang="<%= @locale || 'en' %>" dir="<%= text_direction %>">
  <head>
    <title><%= application_name %> <%= t("page.title_suffix") %></title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="pinterest" content="nopin">
    <meta name="format-detection" content="telephone=no email=no date=no address=no">
    <meta name="robots" content="noindex, nofollow">
    <meta name="referrer" content="no-referrer-when-downgrade">
    <% if dark_mode_selector %>
    <script>
      (function() {
        try {
          if (localStorage.getItem("super_settings_theme") === "dark") {
            document.documentElement.setAttribute("data-theme", "dark");
          }
        } catch (e) {
        }
      })();
    </script>
    <% end %>
    <%= layout_style_tag %>
    <%= add_to_head %>
  </head>

  <body class="super_settings">
    <header class="super-settings-page-header">
      <div class="super-settings-page-header-inner">
        <%= application_header %>
        <% if dark_mode_selector %>
        <button type="button" class="super-settings-theme-toggle" id="super-settings-theme-toggle" aria-label="Toggle dark mode">
          <svg class="super-settings-theme-icon super-settings-theme-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"></circle>
            <path d="M12 2v2"></path>
            <path d="M12 20v2"></path>
            <path d="m4.93 4.93 1.41 1.41"></path>
            <path d="m17.66 17.66 1.41 1.41"></path>
            <path d="M2 12h2"></path>
            <path d="M20 12h2"></path>
            <path d="m6.34 17.66-1.41 1.41"></path>
            <path d="m19.07 4.93-1.41 1.41"></path>
          </svg>
          <svg class="super-settings-theme-icon super-settings-theme-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
          </svg>
        </button>
        <% end %>
      </div>
    </header>

    <div class="super-settings-container">
      <%= yield %>
    </div>

    <% locales = SuperSettings::MiniI18n.available_locales %>
    <% if locales.size > 1 %>
      <footer class="super-settings-page-footer">
        <% locale = @locale || SuperSettings::MiniI18n::DEFAULT_LOCALE %>
        <% current_locale_name = SuperSettings::MiniI18n.t("language.name", locale: locale) %>
        <details class="super-settings-language-menu" id="super-settings-language-menu">
          <summary class="super-settings-language-trigger" aria-label="<%= t('language.label') %>" aria-haspopup="menu">
            <span class="super-settings-language-trigger-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="9"></circle>
                <path d="M3.6 9h16.8"></path>
                <path d="M3.6 15h16.8"></path>
                <path d="M12 3a14 14 0 0 1 0 18"></path>
                <path d="M12 3a14 14 0 0 0 0 18"></path>
              </svg>
            </span>
            <span class="super-settings-language-trigger-current"><%= html_escape(current_locale_name) %></span>
            <span class="super-settings-language-trigger-caret" aria-hidden="true">
              <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                <path d="m4 6 4 4 4-4"></path>
              </svg>
            </span>
          </summary>

          <menu class="super-settings-language-popup" role="menu" aria-label="<%= t('language.label') %>">
            <% locales.each do |loc| %>
              <% language_name = SuperSettings::MiniI18n.t('language.name', locale: loc) %>
              <% active = loc == locale %>
              <li>
                <button
                  type="button"
                  class="super-settings-language-option<%= ' is-active' if active %>"
                  role="menuitemradio"
                  aria-checked="<%= active %>"
                  data-locale="<%= html_escape(loc) %>"
                >
                  <span class="super-settings-language-option-name"><%= html_escape(language_name) %></span>
                  <span class="super-settings-language-option-check" aria-hidden="true">
                    <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                      <path d="m3.5 8 3 3 6-6"></path>
                    </svg>
                  </span>
                </button>
              </li>
            <% end %>
          </menu>
        </details>
      </footer>
    <% end %>
    <% if dark_mode_selector %>
    <script>
      (function() {
        var toggle = document.getElementById("super-settings-theme-toggle");
        if (!toggle) return;

        var html = document.documentElement;
        toggle.addEventListener("click", function() {
          var isDark = html.getAttribute("data-theme") === "dark";
          if (isDark) {
            html.removeAttribute("data-theme");
            try {
              localStorage.removeItem("super_settings_theme");
            } catch (e) {
            }
          } else {
            html.setAttribute("data-theme", "dark");
            try {
              localStorage.setItem("super_settings_theme", "dark");
            } catch (e) {
            }
          }
        });
      })();
    </script>
    <% end %>
  </body>
</html>
